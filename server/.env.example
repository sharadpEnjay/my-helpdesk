# Server environment variables.
# Local dev: copy to `server/.env` and fill in. Production: set these as Railway
# service variables (never commit real secrets).

# --- Core (required) ---
# On Railway, reference the Postgres plugin: ${{ Postgres.DATABASE_URL }}
DATABASE_URL="postgresql://user:password@localhost:5432/my-helpdesk?schema=public"
# Public URL of THIS service (same origin serves the client). No trailing slash.
# e.g. https://your-app.up.railway.app  or your custom domain.
BETTER_AUTH_URL="http://localhost:3001"
# REQUIRED in production — Better Auth throws on boot without it. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="generate-a-random-32-byte-secret"
# Comma-separated. Set to the same public origin(s) as above.
TRUSTED_ORIGINS="http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:5173"
# Enables secure cookies + auth rate limiting. Railway: set to "production".
NODE_ENV="development"
# Railway injects PORT automatically; leave unset there. Local default is 3001.
# PORT=3001

# --- Admin seed (used by prisma/seed.ts and SEED_ON_DEPLOY) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
# Set SEED_ON_DEPLOY=true on Railway to create the admin on first deploy (idempotent).
# SEED_ON_DEPLOY=false

# --- AI (reply polish / auto-resolve) ---
GROK_API_KEY=""

# --- Outbound email (SendGrid) ---
SENDGRID_API_KEY=""
# Must be a verified SendGrid single sender, and equal to IMAP_USER for threading.
SENDGRID_FROM_EMAIL="you@example.com"
SENDGRID_FROM_NAME="Support Team"

# --- Inbound email (IMAP poll of one Gmail label) ---
IMAP_HOST="imap.gmail.com"
IMAP_PORT=993
IMAP_USER="you@example.com"
# Gmail App Password (not your normal password). Poller is skipped if unset.
IMAP_PASSWORD=""
IMAP_MAILBOX="Test"
# IMAP_POLL_INTERVAL_MS=30000

# --- Raw SMTP ingestion (optional; off by default) ---
# Only enable where a public SMTP port is routed. Not used on Railway.
# ENABLE_SMTP_SERVER=false
# SMTP_PORT=2525

# --- Webhook inbound email ---
INBOUND_EMAIL_WEBHOOK_SECRET="change-me"

# --- Error monitoring (optional) ---
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
